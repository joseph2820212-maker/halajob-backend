      "mustNotContain": [
        "VITE_FEATURE_AI_TOOLS_ENABLED"
      ]
    },
    {
      "path": "web/src/shared/settings.tsx",
      "mustContain": [
        "type?: \"text\" | \"number\" | \"checkbox\" | \"choice\"",
        "field.type === \"choice\"",
        "field.type === \"checkbox\"",
        "type=\"radio\"",
        "type=\"checkbox\""
