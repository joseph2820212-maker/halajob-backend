            "title: 'Talent help'",
            "title: 'Campus recruiting'",
            "title: 'Interviews'",
            "title: 'Hiring pipeline'",
            "title: 'Invitations'",
            "title: 'Reviews'",
            "title: 'Account profile'",
            "title: 'Company profile settings'",
