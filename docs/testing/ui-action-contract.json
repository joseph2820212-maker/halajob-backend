    {
      "path": "web/src/company/screens.tsx",
      "mustContain": [
        "aiToolsEnabledFromSettings(clientSettings)",
        "...(webAiToolsEnabled ? [\"ai tools\"] : [])",
        "{webAiToolsEnabled && tab === \"ai tools\" && <CompanyAiPanel",
