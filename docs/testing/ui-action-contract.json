        "VITE_FEATURE_AI_TOOLS_ENABLED"
      ]
    },
    {
      "path": "web/src/campus/screens.tsx",
      "mustContain": [
        "aiToolsEnabledFromSettings(clientSettings)",
        "...(webAiToolsEnabled ? [\"ai tools\"] : [])",
        "{webAiToolsEnabled && mode === \"student\" && tab === \"ai tools\" && (",
