      "occurrences": [
        {
          "text": "title: 'AI hiring tools'",
          "equals": 1
        },
        {
          "text": "key: const ValueKey('company-header-notifications')",
          "equals": 1
        },
        {
          "text": "key: const ValueKey('company-header-profile')",
          "equals": 1
        },
        {
          "text": "key: const ValueKey('company-header-settings')",
          "equals": 1
        },
        {
          "text": "key: const ValueKey('company-header-switch-account')",
          "equals": 1
        },
        {
          "text": "title: 'Talent help'",
          "equals": 1
        },
        {
          "text": "title: 'Campus recruiting'",
          "equals": 1
