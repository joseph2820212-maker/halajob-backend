{
  "version": 1,
  "description": "Critical UI actions that must stay wired to the intended backend route or canonical entry point.",
  "files": [
    {
      "path": "web/src/public/screens.tsx",
      "mustContain": [
        "publicService.companyProfile(companyId)",
        "PublicCompanyProfilePanel",
        "onSearch(query.trim())"
      ],
      "mustNotContain": [
        "selected && go(\"company\")"
      ]
    },
    {
      "path": "web/src/shared/api.ts",
      "mustContain": [
