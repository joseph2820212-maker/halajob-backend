PORT =
CONNECTION_URL =  
JWT_SECRET=  
ACCESS_TOKEN_EXPIRATION_MINUTES= 
REFRESH_TOKEN_EXPIRATION_DAYS= 
# Live backend base URL. jobzain.com is the current backend domain (technical
# URL, not the product brand). Documented temporary exception in
# BRAND_CLEANUP_AUDIT.md; migrate after the Hala Job API domain is DNS/SSL/CORS/
# smoke-tested.
PUBLIC_BASE_URL=https://jobzain.com
HEALTH_SECRET=
CORS_ORIGINS=https://your-vercel-site.vercel.app,https://your-custom-domain.com
CORS_ORIGIN_PATTERNS=https://*.vercel.app

# Optional local/admin seeding. Required if you want seeders to create an admin user.
SEED_ADMIN_ALLOW_CREATE=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FIRST_NAME=
SEED_ADMIN_LAST_NAME=
SEED_ADMIN_PHONE_E164=
SEED_ADMIN_PHONE_COUNTRY=SY
SEED_ADMIN_PHONE_CODE=+963
SEED_ADMIN_PHONE_NATIONAL=
SEED_EMPLOYEE_PASSWORD=
SEED_COMPANY_PASSWORD=

# Hala Job email / SMTP (operated by llill ltd; mail domain halajob.com)
# Set SMTP_PASS and the real mailboxes when ready. Defaults already resolve to @halajob.com.
# Preferred env names use the HALAJOB_ prefix. The older HALA_ names and the
# legacy JOBZAIN_EMAIL_* names are still honoured as backward-compatible
# fallbacks during the brand migration (see BRAND_CLEANUP_AUDIT.md). Deprecated:
# JOBZAIN_EMAIL_INFO / JOBZAIN_EMAIL_* — use HALAJOB_EMAIL_* instead.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@halajob.com
SMTP_PASS=
HALAJOB_MAIL_DOMAIN=halajob.com
HALAJOB_MAIL_FROM_NAME=Hala Job
HALAJOB_EMAIL_INFO=info@halajob.com
HALAJOB_EMAIL_FORGOT_PASSWORD=no-reply@halajob.com
HALAJOB_EMAIL_PASSCODE=no-reply@halajob.com
HALAJOB_EMAIL_SUBSCRIPTION=billing@halajob.com
HALAJOB_EMAIL_CHECKOUT=billing@halajob.com
HALAJOB_EMAIL_CONTACT=support@halajob.com
HALAJOB_EMAIL_APPOINTMENTS=no-reply@halajob.com

# Content-package contact addresses (resolved into legal/help/email content at seed time)
HALAJOB_SUPPORT_EMAIL=support@halajob.com
HALAJOB_PRIVACY_EMAIL=privacy@halajob.com
HALAJOB_LEGAL_EMAIL=legal@halajob.com
HALAJOB_BILLING_EMAIL=billing@halajob.com
HALAJOB_ACCESSIBILITY_EMAIL=accessibility@halajob.com
HALAJOB_PARTNERS_EMAIL=partners@halajob.com
HALAJOB_SECURITY_EMAIL=security@halajob.com

# Dashboard deep links used in notifications. Current live dashboard domains on
# jobzain.com (technical URLs — documented temporary exception in
# BRAND_CLEANUP_AUDIT.md). Repoint once Hala Job dashboard domains are ready.
EMPLOYEE_DASHBOARD_URL=https://employee.jobzain.com/
COMPANY_DASHBOARD_URL=https://company.jobzain.com/

# Backend-owned AI tools. Disabled by default; mobile/web clients never call
# provider APIs directly.
FEATURE_AI_TOOLS_ENABLED=false
VITE_FEATURE_AI_TOOLS_ENABLED=false
FEATURE_CV_PARSING_ENABLED=true
FEATURE_CV_STUDIO_ENABLED=true
FEATURE_RESOURCE_LIBRARY_ENABLED=true
FEATURE_INTERVIEW_PREP_ENABLED=true
FEATURE_SAVED_SEARCHES_ENABLED=true
FEATURE_SMS_ENABLED=false
FEATURE_SALARY_INSIGHTS_ENABLED=true
FEATURE_CAMPUS_CAREER_CENTER_ENABLED=true
FEATURE_VIDEO_INTERVIEWS_ENABLED=true
FEATURE_TALENT_POOL_CRM_ENABLED=true
FEATURE_EMPLOYER_BRANDING_ENABLED=true
FEATURE_MANUAL_WHATSAPP_SHARE_ENABLED=true
FEATURE_OFFICIAL_WHATSAPP_PROVIDER_ENABLED=false
FEATURE_PAYMENTS_MODE=manual
FEATURE_COMPANY_SELF_REGISTER_ENABLED=true
HALA_AI_ENABLED=false
HALA_AI_PROVIDER=
HALA_AI_MODEL=
HALA_AI_API_KEY=
HALA_AI_BASE_URL=https://api.openai.com/v1
HALA_AI_TIMEOUT_MS=30000
HALA_AI_TEMPERATURE=0.2
HALA_AI_INPUT_COST_PER_1M_TOKENS=0
HALA_AI_OUTPUT_COST_PER_1M_TOKENS=0
# Local verification only. In production, mock output is blocked unless this is true.
HALA_AI_ALLOW_MOCK_PROVIDER=false
HALA_AI_DAILY_LIMIT=20
HALA_AI_MONTHLY_LIMIT=200

# CV parsing provider. Keep manual unless a real parser provider is configured.
CV_PARSER_PROVIDER=manual
CV_PARSER_API_KEY=
CV_PARSER_API_URL=
CV_PARSE_JOB_TTL_DAYS=30

# Syria-safe communication defaults. Manual WhatsApp links are allowed; official
# WhatsApp and SMS providers stay disabled until operations configures them.
SMS_PROVIDER=disabled
SMS_API_KEY=
SMS_API_URL=
SMS_SENDER_ID=HalaJob
COMMUNICATION_LOG_RETENTION_DAYS=180
WHATSAPP_BUSINESS_ENABLED=false
OFFICIAL_WHATSAPP_ENABLED=false

# Salary insights. Syria launch surfaces SYP in client settings, while salary
# analytics still keep USD-normalized fields for cross-currency comparison.
SALARY_INSIGHTS_MIN_SAMPLE_SIZE=3
SALARY_INSIGHTS_CACHE_TTL_SECONDS=3600
SALARY_INSIGHTS_DEFAULT_CURRENCY=SYP

# Public web/deep-link bases. Leave empty until the production public domains are final.
PUBLIC_COMPANY_PROFILE_BASE_URL=
PUBLIC_CV_SHARE_BASE_URL=

# Legal/policy content review gate. Staging renders review drafts with their
# legalReviewStatus; production requires required legal pages to be lawyer-approved.
LEGAL_CONTENT_ENFORCEMENT_MODE=staging

# Scheduled jobs / cron
SCHEDULED_JOBS_ENABLED=true
SCHEDULED_JOBS_TIMEZONE=UTC
SCHEDULED_JOBS_RUN_ON_STARTUP=true
SCHEDULED_JOB_BATCH_SIZE=100
SCHEDULED_JOB_NOTIFICATION_CONCURRENCY=10

# Every 15 minutes: closes expired published jobs
CLOSE_EXPIRED_JOBS_CRON=*/15 * * * *

# Every hour: sends 72h/24h deadline reminders to company owners and saved-job employees
JOB_DEADLINE_REMINDERS_CRON=0 * * * *

# Every hour at minute 10: keeps company active job counters accurate
SYNC_COMPANY_ACTIVE_JOB_COUNTS_CRON=10 * * * *

JOB_REMINDER_MAX_SAVED_USERS_PER_JOB=500
JOB_CLOSE_MAX_APPLICANTS_PER_JOB=500
SAVED_SEARCH_ALERTS_LIMIT=20

# --------------------------------------------------------------------------
# External service credentials (push, media, search, video, AI fallback)
# All optional — the related feature stays off / degrades gracefully when the
# values are empty. Never commit real values; set them in the hosting provider
# secret manager. See docs/ENVIRONMENT.md for the authoritative reference.
# --------------------------------------------------------------------------

# Firebase Cloud Messaging (push notifications). Provide EITHER the full
# service-account JSON inline, OR a path to the JSON file on disk. If push is
# not configured the notification service no-ops (POST /notifications still
# records in-app rows). See docs/PUSH_NOTIFICATIONS.md for FCM project setup.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
GOOGLE_APPLICATION_CREDENTIALS=

# Cloudinary media storage (avatars, company logos, uploaded files). Required
# only when serving user uploads through Cloudinary.
CLOUD_NAME=
API_KEY=
API_SECRET=

# MeiliSearch full-text search. Defaults to a local instance
# (http://localhost:7700) with a placeholder key when unset.
MEILI_HOST=
MEILI_KEY=

# Jitsi base URL for company video interviews (FEATURE_VIDEO_INTERVIEWS_ENABLED).
# Falls back to the public https://meet.jit.si when empty; set a self-hosted
# domain for private rooms.
HALA_JITSI_BASE_URL=

# OpenAI API key. Only a backward-compatible fallback for HALA_AI_API_KEY;
# prefer setting HALA_AI_API_KEY above. Leave empty when AI tools are off.
OPENAI_API_KEY=

# --------------------------------------------------------------------------
# Launch-hardening additions (2026-07-01 P0/P1 sweep)
# --------------------------------------------------------------------------

# Redis for the rate-limit store and future shared caches. Required in
# production — without it every rate limiter falls back to a per-process
# MemoryStore that resets across pods and multiplies the effective limit.
# Local dev is fine without Redis (a warning prints and MemoryStore is used).
REDIS_URL=

# CORS bypass. Only useful for local dev. When true, all cross-origin
# requests are accepted (equivalent of "*"). Do NOT set in staging/prod.
ALLOW_ANY_CORS=false

# TRUST_PROXY controls the express "trust proxy" setting used to read the
# real client IP behind Vercel/Cloudflare/nginx. Vercel/Cloudflare = 1,
# a bare host serving the app directly = 0.
TRUST_PROXY=1

# OTP hashing key. Falls back to JWT_SECRET when empty, but set this
# explicitly if you want to rotate the OTP hash key independently.
PASSCODE_SECRET=

# Refresh cookie SameSite value. Auto-selects "none" in production, "lax"
# elsewhere; override to a specific value ("lax" | "strict" | "none")
# only if you have a cross-site cookie need the auto-selector misses.
REFRESH_COOKIE_SAMESITE=

# Puppeteer CV renderer runs Chromium under an SSRF interceptor by default.
# If your host container is already sandboxed (rootless / seccomp), you can
# re-enable --no-sandbox by setting this to true. Never set on a shared host.
PUPPETEER_ALLOW_NO_SANDBOX=false

# CV public download links: dev-only escape hatch. When true, downloads of
# generated CV files whose EmployeeCv row is missing are permitted. Only
# useful when the CV was written to disk but the DB write failed.
ALLOW_UNTRACKED_GENERATED_CV_DOWNLOADS=false

# Prometheus /metrics endpoint. When true, mounts GET /metrics with default
# node metrics + per-route request counters and latency histograms.
METRICS_ENABLED=false

# Sentry error tracking. Leave empty to disable; set to your project DSN
# to start reporting unhandled errors and captured exceptions.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=

# Structured logging. "json" prints one JSON line per event (good for log
# aggregation); "pretty" prints human-readable colored output (good for dev).
LOG_FORMAT=pretty
LOG_LEVEL=info

# Idempotency middleware TTL. POSTs carrying Idempotency-Key get their
# response cached for this many seconds so duplicate submits return the
# stored result instead of re-running the handler. Requires REDIS_URL.
IDEMPOTENCY_KEY_TTL_SECONDS=86400
